# bridge/.env.example — SZABLON zmiennych mostu.
# Skopiuj do bridge/.env (`cp .env.example .env`) i wpisz realne wartości.
# bridge/.env jest w .gitignore — nie trafia do repo.

# Klucz Gemini (Google AI Studio -> Get API key). Most mintuje z niego tokeny,
# klucz NIGDY nie wychodzi do przeglądarki.
GEMINI_API_KEY=PASTE_GEMINI_API_KEY

# Port lokalnego mostu (musi zgadzać się z CONFIG.bridge.url w config.js).
PORT=8787

# Katalog z projektami — most buduje z niego lekki indeks opisów.
PROJECTS_DIR=/Users/jurek/Downloads/Claude/Projects

# whisper.cpp (fallback STT). Zostaw puste, żeby wyłączyć.
# WHISPER_BIN = ścieżka do binarki whisper.cpp; WHISPER_MODEL = ścieżka do modelu (base/small).
WHISPER_BIN=
WHISPER_MODEL=

# Dozwolone originy (CORS). Rozdziel przecinkami, jak dojdzie więcej.
ALLOWED_ORIGINS=http://localhost:8787

# --- Home Assistant (odczyt + sterowanie przez most) ------------------------
# Adres Twojej instancji HA, np. http://homeassistant.local:8123 (bez / na końcu).
# HA_TOKEN = Long-Lived Access Token: HA -> Twój profil (dół lewego menu) ->
# zakładka "Security" -> "Long-lived access tokens" -> "Create Token".
# Token zostaje TYLKO tutaj — most dokłada go po stronie serwera, do przeglądarki
# nigdy nie trafia. Zostaw puste, żeby HA było wyłączone (wszędzie honest 'podłącz HA').
HA_URL=
HA_TOKEN=

# Prefiks encji drukarki Bambu w HA (np. 'x1c') — most po nim wybiera encje
# drukarki i kamerę do /ha/bambu. Zostaw puste, jeśli nie masz drukarki w HA.
HA_BAMBU_PREFIX=
